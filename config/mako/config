font=Noto Sans 11

background-color=#23263499
text-color=#c6d0f5D9
border-color=#c6d0f51F
progress-color=over #c6d0f51F

border-size=1
border-radius=8
padding=8
margin=10

anchor=bottom-right
layer=overlay

default-timeout=5000
max-visible=5
sort=-time
group-by=app-name

[app-name=Screenshot]
default-timeout=2000
on-button-left=exec xdg-open $HOME/Box/screen
