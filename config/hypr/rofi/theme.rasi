@theme "config"

configuration {
	modi: "drun";
    display-drun:" Apps";
    show-icons: true;
    drun-display-format: "{name}";
}

window {width: 300px;}

inputbar {children:["prompt","entry"];}

prompt {
	margin: 6px 0px 6px 6px;
    padding: 2px 6px;
}

entry {
	margin: 6px 6px 6px 4px;
    padding: 2px;
}

listview {
	lines: 10;
	margin: 0px 6px 6px;
}

element {padding: 4px 8px;}

element-icon {
	size: 24px;
	margin: 0 8px 0 0;
}
